# Google Cloud (same setup as creative-approval)
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# For Vercel: base64-encode your service account JSON and set:
# GOOGLE_SERVICE_ACCOUNT_KEY=<base64-string>
# Run: node scripts/encode-key.js

# Gemini API for AI parsing of life updates
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
# or
GEMINI_API_KEY=your-gemini-api-key

# Brave Search API for news headlines (science, tech, finance)
BRAVE_SEARCH_API_KEY=your-brave-api-key
